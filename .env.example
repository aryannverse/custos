# ============================================================
# Custos — Environment Variable Template
# ============================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored and MUST NEVER be committed.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with real values
# ============================================================

# ----------------------------------------------------------
# Groq API Key
# Get yours from: https://console.groq.com/keys
# This key is what Custos uses to call Groq's LLM API.
# ----------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ----------------------------------------------------------
# Custos API Key
# This key protects Custos's own REST endpoints.
# Any client (browser, Streamlit, curl) must send this in
# the Authorization header: "Authorization: Bearer <key>"
# Generate any random string — e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# ----------------------------------------------------------
CUSTOS_API_KEY=your_custos_api_key_here

# ----------------------------------------------------------
# Database Connection
# Default: DuckDB (no server required, file-based).
# The seed script creates the demo e-commerce database at
# this path if DATABASE_URL starts with "duckdb://".
#
# To use a different database (PostgreSQL via Docker later):
#   DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/custos
#
# To connect Custos to YOUR OWN existing database:
#   DATABASE_URL=duckdb:///path/to/your/database.duckdb
#   DATABASE_URL=postgresql+psycopg2://user:pass@host:port/dbname
#
# Custos will introspect the schema automatically regardless
# of which database you point it at.
# ----------------------------------------------------------
DATABASE_URL=duckdb:///data/custos_demo.duckdb

# ----------------------------------------------------------
# Load Demo Data
# Set to "true" to seed the demo e-commerce database on
# startup (only relevant when DATABASE_URL points to the
# demo DuckDB file). Set to "false" when connecting to your
# own existing database — Custos will introspect it as-is.
# ----------------------------------------------------------
LOAD_DEMO_DATA=true

# ----------------------------------------------------------
# Model Configuration (override config/models.toml if set)
# Usually leave these blank — edit config/models.toml instead.
# ----------------------------------------------------------
# PRIMARY_MODEL=
# SECONDARY_MODEL=

# ----------------------------------------------------------
# API Settings
# ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
